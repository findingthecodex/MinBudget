@page "/overview"
@using MinBudget.Domain
@inject BudgetManager BudgetManager

<div class="overview-page">

<h3 class="section-title">Översikt inkomster</h3>
@if (BudgetManager.Incomes.Count == 0)
{
    <p class="empty-msg">Inga inkomster registrerade.</p>
}
else
{
    <table class="overview-table">
        <thead>
            <tr>
                <th @onclick="() => SortIncomeBy(nameof(Income.Category))">Kategori</th>
                <th @onclick="() => SortIncomeBy(nameof(Income.Description))">Notering</th>
                <th class="text-right" @onclick="() => SortIncomeBy(nameof(Income.Amount))">Belopp</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < SortedIncomes.Count; i++)
            {
                var income = SortedIncomes[i];
                var index = BudgetManager.Incomes.IndexOf(income);
                <tr>
                    <td>
                        @if (editingIndexIncome == index)
                        {
                            <InputSelect @bind-Value="editingIncomeCategory" class="table-select">
                                @foreach (var cat in incomeCategories)
                                { <option value="@cat">@cat</option> }
                            </InputSelect>
                        }
                        else
                        {
                            <span class="clickable" @onclick="() => EditIncomeNote(index)">@income.Category</span>
                        }
                    </td>
                    <td>
                        @if (editingIndexIncome == index)
                        {
                            <InputText @bind-Value="editingIncomeDescription" class="table-input" />
                        }
                        else
                        {
                            <span class="clickable @(string.IsNullOrWhiteSpace(income.Description) ? "muted" : "")" @onclick="() => EditIncomeNote(index)">
                                @(string.IsNullOrWhiteSpace(income.Description) ? "Lägg till notering" : income.Description)
                            </span>
                        }
                    </td>
                    <td class="text-right">
                        @if (editingIndexIncome == index)
                        {
                            <InputNumber @bind-Value="editingIncomeAmount" class="table-input-sm" />
                        }
                        else
                        {
                            <span class="clickable" @onclick="() => EditIncomeNote(index)">@income.Amount kr</span>
                        }
                    </td>
                    <td class="actions">
                        @if (editingIndexIncome == index)
                        {
                            <button class="btn-save" @onclick="async () => await SaveIncomeNote(index)">Spara</button>
                            <button class="btn-cancel-sm" @onclick="CancelIncomeEdit">Avbryt</button>
                        }
                        else
                        {
                            <button class="btn-remove" @onclick="async () => await RemoveIncome(index)">Ta bort</button>
                        }
                    </td>
                </tr>
            }
            <tr class="add-row">
                @if (addingIncome)
                {
                    <td><InputSelect @bind-Value="newIncomeCategory" class="table-select">
                        @foreach (var cat in incomeCategories) { <option value="@cat">@cat</option> }
                    </InputSelect></td>
                    <td><InputText @bind-Value="newIncomeDescription" class="table-input" /></td>
                    <td class="text-right"><InputNumber @bind-Value="newIncomeAmount" class="table-input-sm" /></td>
                    <td class="actions">
                        <button class="btn-save" @onclick="async () => await AddIncome()">Spara</button>
                        <button class="btn-cancel-sm" @onclick="CancelAddIncome">Avbryt</button>
                    </td>
                }
                else
                {
                    <td colspan="4" class="add-cell" @onclick="ShowAddIncome">+</td>
                }
            </tr>
        </tbody>
    </table>
}

<h3 class="section-title" style="margin-top: 2.5rem;">Översikt utgifter</h3>
@if (BudgetManager.Expenses.Count == 0)
{
    <p class="empty-msg">Inga utgifter registrerade.</p>
}
else
{
    <table class="overview-table">
        <thead>
            <tr>
                <th @onclick="() => SortExpenseBy(nameof(Expense.Category))">Kategori</th>
                <th @onclick="() => SortExpenseBy(nameof(Expense.Description))">Notering</th>
                <th class="text-right" @onclick="() => SortExpenseBy(nameof(Expense.Amount))">Belopp</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < SortedExpenses.Count; i++)
            {
                var expense = SortedExpenses[i];
                var index = BudgetManager.Expenses.IndexOf(expense);
                <tr>
                    <td>
                        @if (editingIndexExpense == index)
                        {
                            <InputSelect @bind-Value="editingExpenseCategory" class="table-select">
                                @foreach (var cat in expenseCategories) { <option value="@cat">@cat</option> }
                            </InputSelect>
                        }
                        else
                        {
                            <span class="clickable" @onclick="() => EditExpenseNote(index)">@expense.Category</span>
                        }
                    </td>
                    <td>
                        @if (editingIndexExpense == index)
                        {
                            <InputText @bind-Value="editingExpenseDescription" class="table-input" />
                        }
                        else
                        {
                            <span class="clickable @(string.IsNullOrWhiteSpace(expense.Description) ? "muted" : "")" @onclick="() => EditExpenseNote(index)">
                                @(string.IsNullOrWhiteSpace(expense.Description) ? "Lägg till notering" : expense.Description)
                            </span>
                        }
                    </td>
                    <td class="text-right">
                        @if (editingIndexExpense == index)
                        {
                            <InputNumber @bind-Value="editingExpenseAmount" class="table-input-sm" />
                        }
                        else
                        {
                            <span class="clickable" @onclick="() => EditExpenseNote(index)">@expense.Amount kr</span>
                        }
                    </td>
                    <td class="actions">
                        @if (editingIndexExpense == index)
                        {
                            <button class="btn-save" @onclick="async () => await SaveExpenseNote(index)">Spara</button>
                            <button class="btn-cancel-sm" @onclick="CancelExpenseEdit">Avbryt</button>
                        }
                        else
                        {
                            <button class="btn-remove" @onclick="async () => await RemoveExpense(index)">Ta bort</button>
                        }
                    </td>
                </tr>
            }
            <tr class="add-row">
                @if (addingExpense)
                {
                    <td><InputSelect @bind-Value="newExpenseCategory" class="table-select">
                        @foreach (var cat in expenseCategories) { <option value="@cat">@cat</option> }
                    </InputSelect></td>
                    <td><InputText @bind-Value="newExpenseDescription" class="table-input" /></td>
                    <td class="text-right"><InputNumber @bind-Value="newExpenseAmount" class="table-input-sm" /></td>
                    <td class="actions">
                        <button class="btn-save" @onclick="async () => await AddExpense()">Spara</button>
                        <button class="btn-cancel-sm" @onclick="CancelAddExpense">Avbryt</button>
                    </td>
                }
                else
                {
                    <td colspan="4" class="add-cell" @onclick="ShowAddExpense">+</td>
                }
            </tr>
        </tbody>
    </table>
}

@if (suggestedIncomes.Any() || suggestedExpenses.Any())
{
    <h3 class="section-title" style="margin-top: 2.5rem;">Förslag från föregående månad</h3>

    @if (suggestedIncomes.Any())
    {
        <h4 class="subsection-title">Inkomster</h4>
        <table class="overview-table">
            <tbody>
            @foreach (var suggestion in suggestedIncomes)
            {
                <tr class="suggestion-row">
                    <td>@suggestion.Category</td>
                    <td>@(string.IsNullOrWhiteSpace(suggestion.Description) ? "Ingen notering" : suggestion.Description)</td>
                    <td class="text-right">@suggestion.Amount kr</td>
                    <td class="actions">
                        <button class="btn-add-suggestion" @onclick="async () => await AddSuggestedIncome(suggestion)">+</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    @if (suggestedExpenses.Any())
    {
        <h4 class="subsection-title">Utgifter</h4>
        <table class="overview-table">
            <tbody>
            @foreach (var suggestion in suggestedExpenses)
            {
                <tr class="suggestion-row">
                    <td>@suggestion.Category</td>
                    <td>@(string.IsNullOrWhiteSpace(suggestion.Description) ? "Ingen notering" : suggestion.Description)</td>
                    <td class="text-right">@suggestion.Amount kr</td>
                    <td class="actions">
                        <button class="btn-add-suggestion" @onclick="async () => await AddSuggestedExpense(suggestion)">+</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}

</div>

@code {
    private string incomeSortField = nameof(Income.Category);
    private bool incomeSortAsc = true;
    private string expenseSortField = nameof(Expense.Category);
    private bool expenseSortAsc = true;

    private List<Income> SortedIncomes => SortIncomes();
    private List<Expense> SortedExpenses => SortExpenses();

    private List<Income> SortIncomes()
    {
        var list = BudgetManager.Incomes.ToList();
        return incomeSortField switch
        {
            nameof(Income.Category)    => incomeSortAsc ? list.OrderBy(x => x.Category).ToList()    : list.OrderByDescending(x => x.Category).ToList(),
            nameof(Income.Description) => incomeSortAsc ? list.OrderBy(x => x.Description).ToList() : list.OrderByDescending(x => x.Description).ToList(),
            nameof(Income.Amount)      => incomeSortAsc ? list.OrderBy(x => x.Amount).ToList()      : list.OrderByDescending(x => x.Amount).ToList(),
            _ => list
        };
    }

    private List<Expense> SortExpenses()
    {
        var list = BudgetManager.Expenses.ToList();
        return expenseSortField switch
        {
            nameof(Expense.Category)    => expenseSortAsc ? list.OrderBy(x => x.Category).ToList()    : list.OrderByDescending(x => x.Category).ToList(),
            nameof(Expense.Description) => expenseSortAsc ? list.OrderBy(x => x.Description).ToList() : list.OrderByDescending(x => x.Description).ToList(),
            nameof(Expense.Amount)      => expenseSortAsc ? list.OrderBy(x => x.Amount).ToList()      : list.OrderByDescending(x => x.Amount).ToList(),
            _ => list
        };
    }

    private void SortIncomeBy(string field)
    {
        if (incomeSortField == field) incomeSortAsc = !incomeSortAsc;
        else { incomeSortField = field; incomeSortAsc = true; }
    }

    private void SortExpenseBy(string field)
    {
        if (expenseSortField == field) expenseSortAsc = !expenseSortAsc;
        else { expenseSortField = field; expenseSortAsc = true; }
    }

    private int editingIndexIncome = -1;
    private int editingIndexExpense = -1;
    private string? editingIncomeDescription;
    private decimal? editingIncomeAmount;
    private string editingIncomeCategory = "Lön";
    private string? editingExpenseDescription;
    private decimal? editingExpenseAmount;
    private string editingExpenseCategory = "Mat";
    private readonly string[] incomeCategories = { "Lön", "CSN" };
    private readonly string[] expenseCategories = { "Mat", "Hyra", "Nöje", "Transport", "Övrigt", "Spara" };

    private string newIncomeCategory = "Lön";
    private string? newIncomeDescription;
    private decimal? newIncomeAmount;
    private bool addingIncome = false;
    private string newExpenseCategory = "Mat";
    private string? newExpenseDescription;
    private decimal? newExpenseAmount;
    private bool addingExpense = false;

    private List<Income> suggestedIncomes = new();
    private List<Expense> suggestedExpenses = new();

    protected override async Task OnInitializedAsync()
    {
        await BudgetManager.LoadAsync();
        await LoadSuggestions();
    }

    protected override async Task OnParametersSetAsync()
    {
        await BudgetManager.LoadAsync();
        await LoadSuggestions();
        StateHasChanged();
    }

    private async Task LoadSuggestions()
    {
        var suggestions = await BudgetManager.GetPreviousMonthSuggestionsAsync();
        suggestedIncomes = suggestions.Incomes;
        suggestedExpenses = suggestions.Expenses;
    }

    private async Task AddSuggestedIncome(Income income)
    {
        await BudgetManager.AddIncomeAsync(income);
        suggestedIncomes.Remove(income);
        await BudgetManager.LoadAsync();
        StateHasChanged();
    }

    private async Task AddSuggestedExpense(Expense expense)
    {
        await BudgetManager.AddExpenseAsync(expense);
        suggestedExpenses.Remove(expense);
        await BudgetManager.LoadAsync();
        StateHasChanged();
    }

    private void ShowAddIncome() { addingIncome = true; newIncomeCategory = "Lön"; newIncomeDescription = null; newIncomeAmount = null; }
    private void CancelAddIncome() { addingIncome = false; newIncomeCategory = "Lön"; newIncomeDescription = null; newIncomeAmount = null; }

    private async Task AddIncome()
    {
        if (newIncomeAmount is > 0)
        {
            await BudgetManager.AddIncomeAsync(new Income { Category = newIncomeCategory, Amount = newIncomeAmount.Value, Description = newIncomeDescription });
            newIncomeCategory = "Lön"; newIncomeDescription = null; newIncomeAmount = null; addingIncome = false;
            await BudgetManager.LoadAsync(); StateHasChanged();
        }
    }

    private void ShowAddExpense() { addingExpense = true; newExpenseCategory = "Mat"; newExpenseDescription = null; newExpenseAmount = null; }
    private void CancelAddExpense() { addingExpense = false; newExpenseCategory = "Mat"; newExpenseDescription = null; newExpenseAmount = null; }

    private async Task AddExpense()
    {
        if (newExpenseAmount is > 0)
        {
            await BudgetManager.AddExpenseAsync(new Expense { Category = newExpenseCategory, Amount = newExpenseAmount.Value, Description = newExpenseDescription });
            newExpenseCategory = "Mat"; newExpenseDescription = null; newExpenseAmount = null; addingExpense = false;
            await BudgetManager.LoadAsync(); StateHasChanged();
        }
    }

    private async Task RemoveIncome(int index) { await BudgetManager.RemoveIncomeAsync(index); await BudgetManager.LoadAsync(); StateHasChanged(); }
    private async Task RemoveExpense(int index) { await BudgetManager.RemoveExpenseAsync(index); await BudgetManager.LoadAsync(); StateHasChanged(); }

    private void EditIncomeNote(int index)
    {
        editingIndexIncome = index;
        var inc = BudgetManager.Incomes[index];
        editingIncomeDescription = inc.Description; editingIncomeAmount = inc.Amount; editingIncomeCategory = inc.Category;
    }

    private async Task SaveIncomeNote(int index)
    {
        var inc = BudgetManager.Incomes[index];
        inc.Description = editingIncomeDescription; inc.Amount = editingIncomeAmount ?? 0; inc.Category = editingIncomeCategory;
        await BudgetManager.SaveIncomeNoteAsync(index);
        editingIndexIncome = -1; await BudgetManager.LoadAsync(); StateHasChanged();
    }

    private void CancelIncomeEdit() { editingIndexIncome = -1; }

    private void EditExpenseNote(int index)
    {
        editingIndexExpense = index;
        var exp = BudgetManager.Expenses[index];
        editingExpenseDescription = exp.Description; editingExpenseAmount = exp.Amount; editingExpenseCategory = exp.Category;
    }

    private async Task SaveExpenseNote(int index)
    {
        var exp = BudgetManager.Expenses[index];
        exp.Description = editingExpenseDescription; exp.Amount = editingExpenseAmount ?? 0; exp.Category = editingExpenseCategory;
        await BudgetManager.SaveExpenseNoteAsync(index);
        editingIndexExpense = -1; await BudgetManager.LoadAsync(); StateHasChanged();
    }

    private void CancelExpenseEdit() { editingIndexExpense = -1; }
}
