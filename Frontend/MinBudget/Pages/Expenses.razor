@page "/expenses"
@using MinBudget.Services
@inject ApiClientService ApiClient
@inject AuthTokenService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Expenses - MinBudget</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Expenses</h2>
        </div>
        <div class="col-md-4 text-end">
            <button class="btn btn-danger" @onclick="Logout">Logout</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Add New Expense</h5>
                <form @onsubmit="AddExpense">
                    <div class="row">
                        <div class="col-md-3">
                            <input type="number" class="form-control" @bind="newExpense.Amount" 
                                placeholder="Amount" step="0.01" required />
                        </div>
                        <div class="col-md-3">
                            <input type="text" class="form-control" @bind="newExpense.Category" 
                                placeholder="Category" required />
                        </div>
                        <div class="col-md-4">
                            <input type="text" class="form-control" @bind="newExpense.Description" 
                                placeholder="Description" />
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">Add</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="mt-4">
            <h5>Your Expenses</h5>
            @if (expenses?.Count > 0)
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Amount</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var expense in expenses)
                        {
                            <tr>
                                <td>$@expense.Amount</td>
                                <td>@expense.Category</td>
                                <td>@(expense.Description ?? "-")</td>
                                <td>@expense.Date.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteExpense(expense.Id)">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">No expenses yet. Add one to get started!</p>
            }
        </div>
    }
</div>

@code {
    private List<ExpenseResponse>? expenses;
    private string? errorMessage;
    private bool isLoading = true;
    private NewExpense newExpense = new();

    protected override async Task OnInitializedAsync()
    {
        // Check if authenticated
        var isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!isAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadExpenses();
    }

    private async Task LoadExpenses()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var year = DateTime.Now.Year;
            var month = DateTime.Now.Month;
            var response = await ApiClient.GetAsync<List<ExpenseResponse>>($"/api/expenses/month/{year}/{month}");

            if (response.Success)
            {
                expenses = response.Data ?? new List<ExpenseResponse>();
            }
            else
            {
                errorMessage = response.Error ?? "Failed to load expenses";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AddExpense()
    {
        if (newExpense.Amount <= 0)
        {
            errorMessage = "Amount must be greater than 0";
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await ApiClient.PostAsync<ExpenseResponse>("/api/expenses", newExpense);

            if (response.Success)
            {
                newExpense = new();
                await LoadExpenses();
            }
            else
            {
                errorMessage = response.Error ?? "Failed to add expense";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteExpense(int id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this expense?");
        if (!confirmed)
            return;

        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await ApiClient.DeleteAsync($"/api/expenses/{id}");

            if (response.Success)
            {
                await LoadExpenses();
            }
            else
            {
                errorMessage = response.Error ?? "Failed to delete expense";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Logout()
    {
        await AuthService.ClearAsync();
        Navigation.NavigateTo("/login");
    }

    // API Response DTOs
    public class ExpenseResponse
    {
        public int Id { get; set; }
        public decimal Amount { get; set; }
        public string? Description { get; set; }
        public DateTime Date { get; set; }
        public string Category { get; set; } = "Mat";
    }

    public class NewExpense
    {
        public decimal Amount { get; set; }
        public string? Description { get; set; }
        public string Category { get; set; } = "Mat";
        public DateTime Date { get; set; } = DateTime.UtcNow;
    }
}


